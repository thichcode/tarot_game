# Environment template for local development / Vercel
# Copy this file to `.env.local` (Vercel) or load via `source .env.example`.

OPENAI_API_KEY=sk-<your-openai-key-here>
GEMINI_API_KEY=AIza...   # Replace with your Google Gemini key
OPENROUTER_API_KEY=or-k<your-openrouter-key>

# Optional (for advanced flows)
# TAROT_GAME_LOG_LEVEL=debug    # Enable verbose backend logging
# TAROT_GAME_DEFAULT_PROVIDER=openrouter  # Override default provider for quick testing
